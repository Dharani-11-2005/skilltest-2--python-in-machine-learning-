      "source": [
        "import numpy as np\n",
        "\n",
        "# Points\n",
        "p1 = np.array([2, 3])\n",
        "p2 = np.array([5, 7])\n",
        "\n",
        "# Euclidean Distance\n",
        "distance = np.sqrt(np.sum((p1 - p2) ** 2))\n",
        "print(\"Distance:\", distance)\n",
        "\n",
        "# Dot Product\n",
        "dot_product = np.dot(p1, p2)\n",
        "print(\"Dot Product:\", dot_product)"
      ]
    }
  ]
}